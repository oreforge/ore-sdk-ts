{
	"name": "@oreforge/sdk",
	"version": "0.1.4",
	"description": "TypeScript SDK for the ore game server infrastructure platform",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"check": "biome check --write ./src && tsc --noEmit",
		"format": "biome format --write ./src",
		"format:check": "biome format ./src",
		"lint": "biome lint ./src",
		"lint:fix": "biome lint --write ./src",
		"ci": "biome check ./src && tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/oreforge/ore-sdk-ts.git"
	},
	"homepage": "https://github.com/oreforge/ore-sdk-ts#readme",
	"bugs": "https://github.com/oreforge/ore-sdk-ts/issues",
	"keywords": ["ore", "oreforge", "game-server", "infrastructure", "sdk"],
	"license": "MIT",
	"engines": {
		"node": ">=18.0.0"
	},
	"sideEffects": false,
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	}
}
